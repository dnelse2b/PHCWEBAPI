  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning",
        "Hangfire": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Auth": "Information",
        "PHCAPI.Host.Middleware": "Information"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/PHCAPI-.txt",
          "rollingInterval": "Day",
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} [{Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "",
    "ParametersConnection": "",
    "DBconnect": "",
    "CFMGERALConnStr": ""
  },
  "AllowedHosts": "*",
  "AllowedOrigins": [
    "https://uat1.portmaputo.com:9000",
    "http://localhost:7298"
  ],
  "JWT": {
    "ValidAudience": "http://localhost:7298",
    "ValidIssuer": "http://localhost:7298",
    "Secret": "",
    "ExpirationHours": 3
  },
  "AdminUI": {
    "LogoUrl": "https://www.2business-si.com/wp-content/uploads/2024/12/2b_logo_ca_03.svg",
    "LogoAlt": "2Business Solutions",
    "LogoWidth": 180,
    "LogoHeight": 50,
    "Colors": {
      "Primary": "#1a73e8",
      "PrimaryHover": "#1557b0",
      "PrimaryLight": "#e8f0fe",
      "Success": "#1e8e3e",
      "Error": "#d93025",
      "Warning": "#f9ab00",
      "Info": "#1a73e8",
      "TextPrimary": "#202124",
      "TextSecondary": "#5f6368",
      "SidebarBackground": "#ffffff",
      "SidebarText": "#5f6368",
      "SidebarActive": "#e8f0fe",
      "SidebarActiveText": "#1a73e8"
    }
  },
  "RateLimiting": {
    "LoginEndpoint": {
      "Enabled": true,
      "PermitLimit": 3,
      "WindowInSeconds": 10,
      "Algorithm": "FixedWindow",
      "SegmentsPerWindow": 1
    },
    "ParametersCreate": {
      "Enabled": true,
      "PermitLimit": 5,
      "WindowInSeconds": 60,
      "Algorithm": "SlidingWindow",
      "SegmentsPerWindow": 6
    },
    "ParametersDelete": {
      "Enabled": true,
      "PermitLimit": 3,
      "WindowInSeconds": 60,
      "Algorithm": "FixedWindow",
      "SegmentsPerWindow": 1
    },
    "ParametersUpdate": {
      "Enabled": true,
      "PermitLimit": 10,
      "WindowInSeconds": 60,
      "Algorithm": "SlidingWindow",
      "SegmentsPerWindow": 6
    },
    "ParametersQuery": {
      "Enabled": true,
      "PermitLimit": 50,
      "WindowInSeconds": 60,
      "Algorithm": "SlidingWindow",
      "SegmentsPerWindow": 6
    },
    "GlobalLimit": {
      "Enabled": true,
      "PermitLimit": 100,
      "WindowInSeconds": 60,
      "Algorithm": "SlidingWindow",
      "SegmentsPerWindow": 6
    }
  },
  "Caching": {
    "Providers": {
      "Enabled": true,
      "MaxCacheSizeMB": 100,
      "EnablePreWarming": true,
      "DefaultPolicy": {
        "TTLMinutes": 5,
        "Priority": "Normal",
        "CacheAll": true
      },
      "ProviderPolicies": {
        "JWT": {
          "TTLMinutes": 2,
          "Priority": "High",
          "CacheAll": true,
          "Description": "JWT token configuration - short TTL for security"
        },
        "TFR": {
          "TTLMinutes": 15,
          "Priority": "Normal",
          "CacheAll": false,
          "ExcludeOperations": [ "AUTH" ],
          "Description": "Transnet Freight Rail API configurations"
        },
        "MPDC": {
          "TTLMinutes": 15,
          "Priority": "Normal",
          "CacheAll": false,
          "ExcludeOperations": [ "AUTH" ],
          "Description": "Maputo Port Development Company API configurations"
        }
      },
      "PreWarmProviders": [
        {
          "Provider": "JWT",
          "OperationCode": null,
          "Environment": "Development"
        },
        {
          "Provider": "TFR",
          "OperationCode": "GET_ALL_CONSIGNMENTS",
          "Environment": "Development"
        },
        {
          "Provider": "MPDC",
          "OperationCode": "NOTIFYCONSIGMENTS",
          "Environment": "Development"
        }
      ],
      "Monitoring": {
        "LogCacheHits": true,
        "LogCacheMisses": true,
        "LogEvictions": false
      }
    }
  }
}
