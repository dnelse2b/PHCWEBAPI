@page "/Admin/Users/Create"
@model Admin.UI.Pages.Users.CreateModel
@{
    ViewData["Title"] = "Criar Novo Utilizador";
    ViewData["Subtitle"] = "Adicione um novo utilizador ao sistema";
}

<div class="max-w-3xl mx-auto">
    <!-- Back Button -->
    <div class="mb-6">
        <a href="/Admin/Users" class="inline-flex items-center text-gray-600 hover:text-gray-900 transition">
            <i class="fas fa-arrow-left mr-2"></i>Voltar à Lista
        </a>
    </div>
    
    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
        <!-- Header -->
        <div class="bg-gradient-to-r from-primary to-secondary px-8 py-6">
            <div class="flex items-center text-white">
                <div class="w-12 h-12 bg-white bg-opacity-20 rounded-lg flex items-center justify-center mr-4">
                    <i class="fas fa-user-plus text-2xl"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-bold">Novo Utilizador</h2>
                    <p class="text-sm opacity-90">Preencha os dados abaixo para criar um novo utilizador</p>
                </div>
            </div>
        </div>
        
        <!-- Form -->
        <form method="post" class="p-8 space-y-6">
            <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg"></div>
            
            <!-- Username -->
            <div>
                <label asp-for="Input.UserName" class="block text-sm font-medium text-gray-700 mb-2">
                    Nome de Utilizador <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-user text-gray-400"></i>
                    </div>
                    <input asp-for="Input.UserName" 
                           class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                           placeholder="joao.silva">
                </div>
                <span asp-validation-for="Input.UserName" class="text-red-500 text-xs mt-1"></span>
                <p class="mt-1 text-xs text-gray-500">3-20 caracteres alfanuméricos</p>
            </div>
            
            <!-- Email -->
            <div>
                <label asp-for="Input.Email" class="block text-sm font-medium text-gray-700 mb-2">
                    Email <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-envelope text-gray-400"></i>
                    </div>
                    <input asp-for="Input.Email" 
                           class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                           placeholder="joao.silva@empresa.pt">
                </div>
                <span asp-validation-for="Input.Email" class="text-red-500 text-xs mt-1"></span>
            </div>
            
            <!-- Password -->
            <div>
                <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700 mb-2">
                    Password <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-lock text-gray-400"></i>
                    </div>
                    <input asp-for="Input.Password" 
                           class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                           placeholder="••••••••">
                </div>
                <span asp-validation-for="Input.Password" class="text-red-500 text-xs mt-1"></span>
                <div class="mt-2 space-y-1 text-xs text-gray-500">
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-gray-400 w-4 mr-2"></i>
                        <span>Mínimo 6 caracteres</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-gray-400 w-4 mr-2"></i>
                        <span>Deve conter letras maiúsculas e minúsculas</span>
                    </div>
                    <div class="flex items-center">
                        <i class="fas fa-check-circle text-gray-400 w-4 mr-2"></i>
                        <span>Deve conter pelo menos um número</span>
                    </div>
                </div>
            </div>
            
            <!-- Confirm Password -->
            <div>
                <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700 mb-2">
                    Confirmar Password <span class="text-red-500">*</span>
                </label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-lock text-gray-400"></i>
                    </div>
                    <input asp-for="Input.ConfirmPassword" 
                           class="block w-full pl-10 pr-3 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent"
                           placeholder="••••••••">
                </div>
                <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-xs mt-1"></span>
            </div>
            
            <!-- Roles -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-3">
                    Roles <span class="text-gray-500">(opcional)</span>
                </label>
                
                @if (Model.AvailableRoles.Count == 0)
                {
                    <div class="p-4 bg-yellow-50 border border-yellow-200 rounded-lg">
                        <p class="text-sm text-yellow-800">
                            <i class="fas fa-exclamation-triangle mr-2"></i>
                            Nenhuma role disponível no sistema
                        </p>
                    </div>
                }
                else
                {
                    <div class="space-y-2">
                        @foreach (var role in Model.AvailableRoles)
                        {
                            <div class="flex items-center p-3 border border-gray-200 rounded-lg hover:bg-gray-50 transition">
                                <input type="checkbox" 
                                       name="Input.SelectedRoles" 
                                       value="@role.Name"
                                       id="role-@role.Name"
                                       class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded">
                                <label for="role-@role.Name" class="ml-3 flex-1 cursor-pointer">
                                    <span class="text-sm font-medium text-gray-900">@role.Name</span>
                                    <p class="text-xs text-gray-500">@role.Description</p>
                                </label>
                                <span class="px-2 py-1 text-xs font-medium rounded-full bg-purple-100 text-purple-700">
                                    <i class="fas fa-shield-alt"></i>
                                </span>
                            </div>
                        }
                    </div>
                }
                
                <p class="mt-2 text-xs text-gray-500">Selecione as roles que deseja atribuir ao utilizador</p>
            </div>
            
            <!-- Email Confirmed -->
            <div class="flex items-center p-4 bg-gray-50 rounded-lg">
                <input asp-for="Input.EmailConfirmed" 
                       class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded">
                <label asp-for="Input.EmailConfirmed" class="ml-3 block text-sm text-gray-700">
                    <span class="font-medium">Email já confirmado</span>
                    <p class="text-xs text-gray-500">Marque se o utilizador já confirmou o email</p>
                </label>
            </div>
            
            <!-- Divider -->
            <div class="border-t border-gray-200 my-6"></div>
            
            <!-- Actions -->
            <div class="flex items-center justify-between">
                <a href="/Admin/Users"
                   class="px-6 py-3 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition">
                    <i class="fas fa-times mr-2"></i>Cancelar
                </a>
                
                <button type="submit" 
                        class="px-8 py-3 btn-primary text-white rounded-lg font-medium hover:shadow-lg transition">
                    <i class="fas fa-user-plus mr-2"></i>Criar Utilizador
                </button>
            </div>
        </form>
    </div>
    
    <!-- Help Card -->
    <div class="mt-6 bg-blue-50 border border-blue-200 rounded-lg p-4">
        <div class="flex">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle text-blue-500 text-xl"></i>
            </div>
            <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-800">Requisitos de Password</h3>
                <div class="mt-2 text-sm text-blue-700">
                    <ul class="list-disc list-inside space-y-1">
                        <li>Mínimo 6 caracteres</li>
                        <li>Pelo menos uma letra maiúscula</li>
                        <li>Pelo menos uma letra minúscula</li>
                        <li>Pelo menos um número</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
