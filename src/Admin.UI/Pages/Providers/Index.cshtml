@page "/Admin/Providers"
@model Admin.UI.Pages.Providers.IndexModel
@{
    ViewData["Title"] = "Gestão de Providers";
    ViewData["Subtitle"] = "Consulte e gerencie todos os providers externos";
}

<!-- Success Message -->
@if (Model.SuccessMessage != null)
{
    <div class="mb-6 bg-green-50 border border-green-200 rounded-lg p-4 animate-slide-in">
        <div class="flex items-center">
            <i class="fas fa-check-circle text-green-600 text-xl mr-3"></i>
            <p class="text-sm font-medium text-green-800">@Model.SuccessMessage</p>
        </div>
    </div>
}

<!-- Error Message -->
@if (Model.ErrorMessage != null)
{
    <div class="mb-6 bg-red-50 border border-red-200 rounded-lg p-4 animate-slide-in">
        <div class="flex items-center">
            <i class="fas fa-exclamation-circle text-red-600 text-xl mr-3"></i>
            <p class="text-sm font-medium text-red-800">@Model.ErrorMessage</p>
        </div>
    </div>
}

<!-- Header Actions -->
<div class="flex items-center justify-between mb-6">
    <div class="flex items-center space-x-4">
        <div class="px-4 py-2 bg-white rounded-lg border border-gray-200 shadow-sm">
            <span class="text-sm font-medium text-gray-600">Total: </span>
            <span class="text-lg font-bold text-primary">@Model.Providers.Count</span>
        </div>
        <div class="px-4 py-2 bg-green-50 rounded-lg border border-green-200 shadow-sm">
            <span class="text-sm font-medium text-green-600">Ativos: </span>
            <span class="text-lg font-bold text-green-700">@Model.Providers.Count(p => p.Ativo)</span>
        </div>
    </div>
    
    <div class="flex space-x-3">
        <a href="/Admin/Providers" class="px-4 py-3 bg-white border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition">
            <i class="fas fa-sync-alt mr-2"></i>Actualizar
        </a>
        <a href="/Admin/Providers/Create" class="px-6 py-3 btn-primary text-white rounded-lg font-medium hover:shadow-lg transition">
            <i class="fas fa-plus mr-2"></i>Novo Provider
        </a>
    </div>
</div>

<!-- Providers Table -->
<div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
    @if (Model.Providers.Count == 0)
    {
        <div class="p-12 text-center">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-gray-100 mb-4">
                <i class="fas fa-plug text-3xl text-gray-400"></i>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Nenhum provider encontrado</h3>
            <p class="text-gray-500 mb-6">Comece por configurar o primeiro provider externo.</p>
            <a href="/Admin/Providers/Create" class="inline-flex items-center px-6 py-3 btn-primary text-white rounded-lg font-medium hover:shadow-lg transition">
                <i class="fas fa-plus mr-2"></i>Criar Primeiro Provider
            </a>
        </div>
    }
    else
    {
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Provider
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Environment
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Descrição
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Configurações
                        </th>
                        <th scope="col" class="px-6 py-4 text-left text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Estado
                        </th>
                        <th scope="col" class="px-6 py-4 text-right text-xs font-bold text-gray-700 uppercase tracking-wider">
                            Ações
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @foreach (var provider in Model.Providers.OrderBy(p => p.Codigo))
                    {
                        <tr class="hover:bg-gray-50 transition">
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="w-10 h-10 flex-shrink-0">
                                        <div class="w-10 h-10 rounded-full @(provider.Ativo ? "bg-primary" : "bg-gray-400") flex items-center justify-center text-white font-medium text-sm">
                                            @provider.Provedor.Substring(0, Math.Min(2, provider.Provedor.Length)).ToUpper()
                                        </div>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-bold text-gray-900">@provider.Provedor</div>
                                        <div class="text-xs text-gray-500">Código: @provider.Codigo</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full 
                                    @(provider.Environment == "Production" ? "bg-red-100 text-red-800" : 
                                      provider.Environment == "Staging" ? "bg-yellow-100 text-yellow-800" : 
                                      "bg-blue-100 text-blue-800")">
                                    @provider.Environment
                                </span>
                            </td>
                            <td class="px-6 py-4">
                                <div class="text-sm text-gray-900 max-w-md truncate" title="@provider.Descricao">
                                    @provider.Descricao
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <div class="text-sm text-gray-900">
                                    <i class="fas fa-cogs text-gray-400 mr-2"></i>
                                    @provider.Values.Count operações
                                </div>
                                <div class="text-xs text-gray-500">
                                    @string.Join(", ", provider.Values.Select(v => v.OperationCode).Distinct().Take(2))
                                    @if (provider.Values.Select(v => v.OperationCode).Distinct().Count() > 2)
                                    {
                                        <text>...</text>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                @if (provider.Ativo)
                                {
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-green-100 text-green-800">
                                        <i class="fas fa-check-circle mr-1"></i> Ativo
                                    </span>
                                }
                                else
                                {
                                    <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                        <i class="fas fa-times-circle mr-1"></i> Inativo
                                    </span>
                                }
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-3">
                                    <a href="/Admin/Providers/Edit?stamp=@provider.UProviderStamp" class="text-blue-600 hover:text-blue-900" title="Editar">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <form method="post" asp-page-handler="Delete" asp-route-stamp="@provider.UProviderStamp" 
                                          onsubmit="return confirm('Tem certeza que deseja eliminar o provider @provider.Provedor? Esta ação não pode ser desfeita.');" 
                                          class="inline">
                                        <button type="submit" class="text-red-600 hover:text-red-900" title="Eliminar">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
