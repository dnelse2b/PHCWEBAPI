@page "/Admin/Account/Logout"
@model Admin.UI.Pages.Account.LogoutModel
@{
    ViewData["Title"] = "Logout";
}

<div class="min-h-screen flex items-center justify-center bg-gradient-to-br from-purple-600 via-purple-700 to-indigo-800">
    <div class="bg-white/10 backdrop-blur-lg p-8 rounded-2xl shadow-2xl text-center">
        <div class="mb-6">
            <div class="w-20 h-20 mx-auto bg-green-500 rounded-full flex items-center justify-center">
                <i class="fas fa-check text-white text-3xl"></i>
            </div>
        </div>
        <h1 class="text-3xl font-bold text-white mb-4">Logout Successful</h1>
        <p class="text-white/80 mb-6">You have been successfully logged out.</p>
        <a href="/Admin/Account/Login" class="inline-block px-6 py-3 bg-white text-purple-700 rounded-lg hover:bg-purple-50 transition-all">
            <i class="fas fa-sign-in-alt mr-2"></i>Login Again
        </a>
    </div>
</div>
