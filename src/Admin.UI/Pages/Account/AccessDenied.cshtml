@page "/Admin/Account/AccessDenied"
@model Admin.UI.Pages.Account.AccessDeniedModel
@{
    ViewData["Title"] = "Acesso Negado";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt" class="h-full bg-white">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Acesso Negado - Admin Panel</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Font Awesome Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
    
    <style>
        * {
            font-family: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
        }
    </style>
</head>
<body class="h-full flex items-center justify-center bg-gray-50">
    <div class="text-center px-6">
        <div class="mb-6">
            <div class="w-20 h-20 mx-auto bg-red-100 rounded-full flex items-center justify-center">
                <i class="fas fa-ban text-red-600 text-3xl"></i>
            </div>
        </div>
        <h1 class="text-2xl font-semibold text-gray-900 mb-3">Acesso Negado</h1>
        <p class="text-gray-600 mb-8 max-w-md">
            Não tem permissão para aceder a este recurso.
        </p>
        <div class="space-x-4">
            <a href="/Admin/Account/Logout" class="inline-block px-6 py-2.5 bg-primary text-white rounded hover:bg-blue-700 transition text-sm font-medium">
                <i class="fas fa-sign-out-alt mr-2"></i>Terminar Sessão
            </a>
        </div>
    </div>
</body>
</html>
