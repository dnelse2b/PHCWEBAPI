@page "/Admin/Roles/Create"
@model Admin.UI.Pages.Roles.CreateModel
@{
    ViewData["Title"] = "Nova Role";
    ViewData["Subtitle"] = "Criar nova role de permissões";
}

<!-- Breadcrumb -->
<nav class="mb-6">
    <ol class="flex items-center space-x-2 text-sm text-gray-600">
        <li><a href="/Admin/Roles" class="hover:text-primary transition"><i class="fas fa-shield-alt mr-1"></i>Roles</a></li>
        <li><i class="fas fa-chevron-right text-xs"></i></li>
        <li class="text-gray-900 font-medium">Nova Role</li>
    </ol>
</nav>

<div class="max-w-2xl mx-auto">
    <!-- Info Card -->
    <div class="bg-blue-50 border border-blue-200 rounded-xl p-4 mb-6">
        <div class="flex items-start">
            <div class="flex-shrink-0">
                <i class="fas fa-info-circle text-blue-600 text-xl"></i>
            </div>
            <div class="ml-3">
                <h3 class="text-sm font-medium text-blue-900 mb-1">Convenções de Nomenclatura</h3>
                <ul class="text-sm text-blue-700 space-y-1">
                    <li>• Use <strong>PascalCase</strong> (primeira letra maiúscula): ContentEditor, OrderManager</li>
                    <li>• Nomes descritivos e concisos (3-50 caracteres)</li>
                    <li>• Evite caracteres especiais ou espaços</li>
                </ul>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <!-- Header -->
        <div class="bg-primary p-6">
            <h2 class="text-xl font-semibold text-white flex items-center">
                <i class="fas fa-plus-circle mr-3"></i>
                Criar Nova Role
            </h2>
        </div>

        <!-- Form -->
        <form method="post" class="p-6">
            <div asp-validation-summary="All" class="mb-4 p-4 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm" style="display: none;"></div>

            <div class="space-y-6">
                <!-- Role Name -->
                <div>
                    <label asp-for="Input.Name" class="block text-sm font-medium text-gray-700 mb-2">
                        Nome da Role <span class="text-red-500">*</span>
                    </label>
                    <input asp-for="Input.Name" 
                           class="block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition"
                           placeholder="ContentEditor"
                           autofocus>
                    <span asp-validation-for="Input.Name" class="text-red-500 text-sm mt-1"></span>
                    <p class="mt-2 text-sm text-gray-500">
                        <i class="fas fa-lightbulb mr-1"></i>
                        Exemplo: ContentEditor, OrderManager, ReportViewer
                    </p>
                </div>

                <!-- Description (Optional) -->
                <div>
                    <label asp-for="Input.Description" class="block text-sm font-medium text-gray-700 mb-2">
                        Descrição <span class="text-gray-400 text-xs">(opcional)</span>
                    </label>
                    <textarea asp-for="Input.Description" 
                              rows="3"
                              class="block w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent transition"
                              placeholder="Descreva as permissões e responsabilidades desta role..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-red-500 text-sm mt-1"></span>
                    <p class="mt-2 text-sm text-gray-500">Máximo 200 caracteres</p>
                </div>

                <!-- Example Roles -->
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                    <h4 class="text-sm font-medium text-gray-900 mb-3">
                        <i class="fas fa-star text-yellow-500 mr-1"></i>
                        Exemplos de Roles Comuns
                    </h4>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2 text-sm">
                        <div class="flex items-center text-gray-700">
                            <i class="fas fa-circle text-xs text-green-500 mr-2"></i>
                            <span><strong>ContentEditor</strong> - Editar conteúdos</span>
                        </div>
                        <div class="flex items-center text-gray-700">
                            <i class="fas fa-circle text-xs text-blue-500 mr-2"></i>
                            <span><strong>OrderManager</strong> - Gerir pedidos</span>
                        </div>
                        <div class="flex items-center text-gray-700">
                            <i class="fas fa-circle text-xs text-purple-500 mr-2"></i>
                            <span><strong>ReportViewer</strong> - Ver relatórios</span>
                        </div>
                        <div class="flex items-center text-gray-700">
                            <i class="fas fa-circle text-xs text-orange-500 mr-2"></i>
                            <span><strong>CustomerSupport</strong> - Apoio ao cliente</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex items-center justify-end space-x-4 mt-8 pt-6 border-t border-gray-200">
                <a href="/Admin/Roles" class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition">
                    <i class="fas fa-times mr-2"></i>Cancelar
                </a>
                <button type="submit" class="px-6 py-3 btn-primary text-white rounded-lg font-medium hover:shadow-lg transition">
                    <i class="fas fa-check mr-2"></i>Criar Role
                </button>
            </div>
        </form>
    </div>

    <!-- System Roles Reference -->
    <div class="mt-6 bg-purple-50 border border-purple-200 rounded-xl p-4">
        <h4 class="text-sm font-medium text-purple-900 mb-2 flex items-center">
            <i class="fas fa-lock text-purple-600 mr-2"></i>
            Roles do Sistema (não podem ser criadas manualmente)
        </h4>
        <div class="flex flex-wrap gap-2">
            <span class="px-3 py-1 bg-white border border-purple-200 rounded-full text-xs font-medium text-purple-700">
                Administrator
            </span>
            <span class="px-3 py-1 bg-white border border-purple-200 rounded-full text-xs font-medium text-purple-700">
                InternalUser
            </span>
            <span class="px-3 py-1 bg-white border border-purple-200 rounded-full text-xs font-medium text-purple-700">
                ApiUser
            </span>
            <span class="px-3 py-1 bg-white border border-purple-200 rounded-full text-xs font-medium text-purple-700">
                AuditViewer
            </span>
            <span class="px-3 py-1 bg-white border border-purple-200 rounded-full text-xs font-medium text-purple-700">
                ExternalStakeholder
            </span>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
